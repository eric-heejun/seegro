CAFE24_CLIENT_ID=your-client-id
CAFE24_CLIENT_SECRET=your-client-secret
CAFE24_MALL_ID=your-mall-id
CAFE24_REDIRECT_URI=https://seegro.vercel.app/api/cafe24/callback
CAFE24_SCOPES=mall.read_order,mall.read_product,mall.read_salesreport,mall.read_store
KV_REST_API_URL=https://your-upstash-redis-url
KV_REST_API_TOKEN=your-upstash-redis-token
# Optional. Use a different key only if multiple Seegro apps share one Redis database.
# CAFE24_TOKEN_STORE_KEY=seegro:cafe24:token
APP_URL=https://seegro.vercel.app
NAVER_COMMERCE_CLIENT_ID=your-naver-commerce-client-id
NAVER_COMMERCE_CLIENT_SECRET=your-naver-commerce-client-secret
NAVER_COMMERCE_TOKEN_TYPE=SELF
# Only set this when NAVER_COMMERCE_TOKEN_TYPE=SELLER.
# NAVER_COMMERCE_ACCOUNT_ID=your-store-account-id
NAVER_COMMERCE_PROXY_URL=https://your-fixed-ip-proxy.example.com
NAVER_COMMERCE_PROXY_SECRET=your-long-random-proxy-secret
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=act_1234567890
META_GRAPH_API_VERSION=v25.0
